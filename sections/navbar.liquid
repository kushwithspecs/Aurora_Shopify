<!-- ─── NAVBAR ─── -->
<nav class="navbar" id="navbar" aria-label="Primary">
  <div class="navbar__inner">
    <a href="/" class="navbar__logo" aria-label="Aurore home">
      <svg class="navbar__logo-mark" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <circle cx="16" cy="16" r="14" stroke="#1C1C1C" stroke-width="1.2"/>
        <path d="M8 20 L16 6 L24 20 Z" stroke="#1C1C1C" stroke-width="1.2" fill="none"/>
        <line x1="11" y1="20" x2="21" y2="20" stroke="#1C1C1C" stroke-width="1.2"/>
      </svg>
      <span class="navbar__logo-text">Aurore</span>
    </a>

    <div class="navbar__right">
      <div class="navbar__links">
        <a href="/collections/rings" class="navbar__link">Rings</a>
        <a href="/collections/necklaces" class="navbar__link">Necklaces</a>
        <a href="/collections/earrings" class="navbar__link">Earrings</a>
        <a href="/collections/lumiere" class="navbar__link">Lumière</a>
      </div>
      <div class="navbar__icons">
        <button class="navbar__icon" aria-label="Search">
          <svg width="20" height="20" viewBox="0 0 256 256" aria-hidden="true">
            <path fill="currentColor" d="M232.49,215.51,185,168a92.12,92.12,0,1,0-17,17l47.53,47.54a12,12,0,0,0,17-17ZM44,112a68,68,0,1,1,68,68A68.07,68.07,0,0,1,44,112Z"/>
          </svg>
        </button>
        <button class="navbar__icon" aria-label="Bag">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          <span class="navbar__count">{{ cart.item_count }}</span>
        </button>
        <button class="navbar__burger" id="navBurger" aria-label="Open menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <line x1="3" y1="7" x2="21" y2="7"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="17" x2="21" y2="17"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</nav>

<!-- ─── MOBILE MENU OVERLAY ─── -->
<div class="mobile-menu" id="mobileMenu" role="dialog" aria-modal="true" aria-label="Mobile menu">
  <div class="mobile-menu__header">
    <span class="navbar__logo-text">Aurore</span>
    <button class="mobile-menu__close" id="menuClose" aria-label="Close menu">✕</button>
  </div>
  <div class="mobile-menu__links">
    <a href="/collections/rings">Rings</a>
    <a href="/collections/necklaces">Necklaces</a>
    <a href="/collections/earrings">Earrings</a>
    <a href="/collections/lumiere">Lumière</a>
    <a href="/collections/all">All Collections</a>
  </div>
</div>

{% schema %}
{
  "name": "Navbar",
  "settings": []
}
{% endschema %}
