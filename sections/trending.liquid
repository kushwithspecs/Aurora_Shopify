<!-- ─── TRENDING — Auto-scroll product track ─── -->
<section class="trending">
  <div class="trending__head">
    <div class="reveal">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description }}</p>
    </div>
    <a href="{{ section.settings.cta_link }}" class="link-underline reveal delay-1">{{ section.settings.cta_text }} <span class="arrow">↗</span></a>
  </div>
  <div class="trending-track" data-marquee>
    <div class="trending-track__inner">
      {% for product in collections.featured.products limit: 12 %}
        <a href="{{ product.url }}" class="product-card">
          <div class="product-card__img-wrap">
            <img class="img-primary" src="{{ product.featured_image | img_url: '400x' }}" alt="{{ product.title }}" />
            {% if product.images[1] %}
              <img class="img-secondary" src="{{ product.images[1] | img_url: '400x' }}" alt="{{ product.title }}" />
            {% endif %}
            <button class="product-card__add">Add to Bag</button>
          </div>
          <div class="product-card__info">
            {% if product.tags contains 'exclusive' %}
              <span class="product-card__badge">Exclusive</span>
            {% endif %}
            <p class="product-card__name">{{ product.title }}</p>
            <p class="product-card__price">{{ product.price | money }}</p>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trending Products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What's trending."
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "The pieces our clients are reaching for this season."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Browse the collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Trending Products"
    }
  ]
}
{% endschema %}
